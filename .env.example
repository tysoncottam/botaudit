# Copy this to .env.local and fill in your values.
# .env.local is loaded by dotenv and is gitignored.

# ── Stripe ─────────────────────────────────────────────────────────────────
# Get keys from https://dashboard.stripe.com/apikeys.
# Leave blank to run in DEMO MODE (no payment required — local dev only).
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...

# ── Public URL ─────────────────────────────────────────────────────────────
# Used for Stripe success/cancel redirects and email download links.
# Production: https://botaudit.app
# Local dev:  leave blank (defaults to http://localhost:3000)
BASE_URL=https://botaudit.app

# ── Email notifications (optional) ─────────────────────────────────────────
# Gmail SMTP works with an App Password (https://myaccount.google.com/apppasswords).
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=you@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=BotAudit <you@gmail.com>

# Optional BCC for completion-notification emails (admin observability)
ADMIN_EMAIL=tysoncottam@gmail.com

# ── Admin endpoints ────────────────────────────────────────────────────────
# Required to call /api/emails. Pick something long and random.
ADMIN_KEY=

# ── Server ─────────────────────────────────────────────────────────────────
PORT=3000

# ── Notes for the new Cloudflare Tunnel deploy ─────────────────────────────
# The server runs locally on the Mac and is exposed via cloudflared.
# See DEPLOYMENT.md for one-time setup. No Railway-specific env vars needed.
