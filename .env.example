# Copy this to .env and fill in your values

# Stripe keys (get from https://dashboard.stripe.com/apikeys)
# Leave blank to run in DEMO MODE (no payment required — good for testing)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...

# Your deployed domain (used for Stripe redirect URLs)
# For local dev, leave blank — defaults to http://localhost:3000
BASE_URL=https://yourdomain.com

# Email notifications (optional — leave blank to disable)
# Works with Gmail (use an App Password), any SMTP host, etc.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=you@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=BotAudit <you@gmail.com>

# Server port
PORT=3000
